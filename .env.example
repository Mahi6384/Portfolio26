# Contact form (Resend — free tier). Copy to .env.local and fill in.
# IMPORTANT: generate a FRESH key at https://resend.com/api-keys — never reuse the old leaked one.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form messages are delivered
CONTACT_TO_EMAIL=mahijaincodes@gmail.com

# Verified sender. Until you verify a domain in Resend, use their onboarding sender:
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# Canonical site URL (used for OG images, sitemap, JSON-LD). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://mahijain.vercel.app
